(mautrix) {
	@isMautrixWellKnown path /.well-known/matrix/mautrix
	handle @isMautrixWellKnown {
		header Content-Type application/json
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, OPTIONS"
		header Access-Control-Allow-Headers "Origin, Content-Type, Accept"
		header Access-Control-Max-Age "86400"
		respond `{"fi.mau.bridges":["https://matrix-discord.taila659a.ts.net","https://matrix-googlechat.taila659a.ts.net","https://matrix-linkedin.taila659a.ts.net","https://matrix-meta.taila659a.ts.net","https://matrix-signal.taila659a.ts.net","https://matrix-slack.taila659a.ts.net","https://matrix-twitter.taila659a.ts.net","https://matrix-whatsapp.taila659a.ts.net"]}` 200
	}
}

(matrix-discord-media-http) {
	@isDiscordDirectMediaApi path /.well-known/matrix/server /_matrix/federation/v1/media/download/* /_matrix/client/v1/media/* /_matrix/media/* /_matrix/key/* /_matrix/federation/v1/version
	handle @isDiscordDirectMediaApi {
		reverse_proxy http://matrix-discord:29334
	}
	handle {
		respond 404
	}
}

(matrix-discord-media-https) {
	@isDiscordDirectMediaApi path /.well-known/matrix/server /_matrix/federation/v1/media/download/* /_matrix/client/v1/media/* /_matrix/media/* /_matrix/key/* /_matrix/federation/v1/version
	handle @isDiscordDirectMediaApi {
		reverse_proxy https://matrix-discord:29334 {
			transport http {
				tls_server_name matrix-discord
			}
		}
	}
}

(matrix-funnel-http) {
	@isSynapseSensitive path /_synapse/admin/* /_synapse/replication/* /_synapse/metrics* /_synapse/client/*
	handle @isSynapseSensitive {
		respond 404
	}
	handle {
		reverse_proxy http://matrix:8008
	}
}

(matrix-funnel-https) {
	@isSynapseSensitive path /_synapse/admin/* /_synapse/replication/* /_synapse/metrics* /_synapse/client/*
	handle @isSynapseSensitive {
		respond 404
	}
	handle {
		reverse_proxy https://matrix:8448 {
			transport http {
				tls_server_name matrix
			}
		}
	}
}

(matrix-https) {
	import mautrix
	reverse_proxy https://matrix:8448 {
		transport http {
			tls_server_name matrix
		}
	}
}

(matrix-http) {
	import mautrix
	reverse_proxy http://matrix:8008
}

:8008 {
	log
	@isDiscordDirectMedia host matrix-discord-media.taila659a.ts.net
	handle @isDiscordDirectMedia {
		import matrix-discord-media-http
	}
	@isFunnel header Tailscale-Funnel-Request ?1
	handle @isFunnel {
		import matrix-funnel-http
	}
	handle {
		import matrix-http
	}
}

:8448 {
	tls /etc/ssl/private/tls.crt /etc/ssl/private/tls.key
	log
	@isDiscordDirectMedia host matrix-discord-media.taila659a.ts.net
	handle @isDiscordDirectMedia {
		import matrix-discord-media-https
	}
	@isFunnel header Tailscale-Funnel-Request ?1
	handle @isFunnel {
		import matrix-funnel-https
	}
	handle {
		import matrix-https
	}
}
